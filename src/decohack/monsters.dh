thing Archvile "Bishop"
{
	Speed 25

	clear states
	states
	{
	Spawn:
		BISH A 10 A_Look
		Loop
	See:
		BISH AAAAAAAA 4 A_VileChase
	TeleportAway:
		TFOG AC 5 Bright
    Melee: // try to stay away from the player
		NONE A 1
		BISH AAAAAAA 0 A_VileChase
		NONE A 1
		TFOG C 6 Bright
		TFOG A 6 Bright
    LightAttack:
		BISH D 4 Bright A_FaceTarget
		BISH E 4 Bright A_FaceTarget
		BISH F 8 Bright	A_BruisAttack
		Goto See
	Missile:
		TFOG C 6 Bright A_VileTarget
		TFOG A 5 Bright A_VileTarget
		BISH A 1 Bright A_BspiAttack
		Goto LightAttack
	Pain:
		BISH C 6
		BISH C 6 A_Pain
		Goto Missile
	Death:
		BISH H 6 Bright A_Scream
		BISH I 5 Bright A_Fall
		BISH JKLMN 4
		BISH P -1
		Stop
	}
}

state unprotect S_VILE_HEAL1 to S_VILE_HEAL3
state free S_VILE_HEAL1 to S_VILE_HEAL3

state fill S_VILE_HEAL1
{
	BISH DEF 10 Bright
	Goto thing Archvile See
}

state protect S_VILE_HEAL1 to S_VILE_HEAL3

thing ArchvileFire "Bishop Clone"
{
	-SOLID
	+SHOOTABLE
	+TRANSLATION
	+NOBLOOD
	-NOBLOCKMAP
	Health 1
	Radius 8
	Speed -50

	clear states
	states
	{
	Spawn:
		NONE A 1
		NONE A 1 A_Look
		Wait
	See:
		BISG AAA 0 A_Chase
		NONE A 1
	Missile:
		TFOG CA 5 Bright A_FaceTarget
		BISG D 4 Bright A_FaceTarget
		BISG E 4 Bright A_FaceTarget
		BISG F 1 Bright	A_TroopAttack
		BISG F 7 Bright A_Fall
		Goto S_TFOG
	Death:
		BISG C 1
		Goto S_TFOG
	}
}

