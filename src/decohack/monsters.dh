thing Zombieman "Golem"
{
	Health 50
	Painchance 128
	Speed 6

	AttackSound ""

	clear states
	states
	{
	Spawn:
		MUMM A 10 A_Look
		Loop
	See:
		MUMM AABBCCDD 2 A_Chase
		Loop
	Melee:
		MUMM E 6 A_FaceTarget
		MUMM F 5 A_SargAttack
		MUMM G 5
		Goto See
	Pain:
		MUMM H 8 A_Pain
		Goto See
	Death:
		MUMM I 5
		MUMM J 5 A_Scream
		MUMM KL 5
		MUMM M 5 A_Fall
		MUMM NO 5
		MUMM P -1
		Stop
	Raise:
		MUMM ONMLKJI 5
		Goto See
	}
}

thing ShotgunGuy : thing Zombieman "Nitrogolem"
{
	PainChance 64
	Health 60
	ednum 9

	states
	{
	Missile:
		MUMM R 4 A_FaceTarget
		MUMM Q 4 Bright A_FaceTarget
		MUMM R 4 A_FaceTarget
		MUMM Q 4 Bright A_FaceTarget
		MUMM R 4 A_FaceTarget
		MUMM Q 4 Bright { A_TroopAttack A_TroopAttack }
		Goto See
	}
}

thing ChaingunGuy "Evil Mage" // yeah creative name I know
{
	clear states
	states
	{
	Spawn:
		MAGE A 10 A_Look
		Loop
	See:
		MAGE AABBCCDD 3 A_Chase
		Loop
	Missile:
		MAGE E 10 A_FaceTarget
	Refiring:
		MAGE FE 4 Bright A_CPosAttack
		MAGE F 1 A_CPosRefire
		Goto Refiring
	Pain:
		MAGE G 3
		MAGE G 3 A_Pain
		Goto See
	Death:
		MAGE H 5
		MAGE I 5 A_Scream
		MAGE J 5 A_Fall
		MAGE KLM 5
		MAGE N -1
		Stop
	XDeath:
		MAGE O 5
		MAGE P 5 A_XScream
		MAGE Q 5 A_Fall
		MAGE RSTUVW 5
		MAGE X -1
		Stop
	Raise:
		MAGE N 5
		MAGE MLKJIH 5
		Goto See
	}
}

thing WolfensteinSS : thing ChaingunGuy
{
	ednum 84
}

